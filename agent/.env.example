# Cost Analyst Agent — secrets template.
# Copy to `.env` and fill in. NEVER commit the real .env (it is git-ignored).
# Secrets are loaded from here into the environment at startup (python-dotenv).
# Non-secret parameters are passed as CLI flags instead (see README / --help).

# ---- Required: OpenAI (the model) ----
OPENAI_API_KEY=sk-your-key-here

# ---- Optional: read-only AWS credentials (enables live AWS verification) ----
# Use a read-only IAM principal (e.g. ReadOnlyAccess + AWSBillingReadOnlyAccess).
# Cost Explorer is global; us-east-1 is a safe default region.
# AWS_ACCESS_KEY_ID=AKIA-EXAMPLE-READONLY
# AWS_SECRET_ACCESS_KEY=example-secret-do-not-commit
# AWS_SESSION_TOKEN=
# AWS_REGION=us-east-1

# You may instead rely on a shared profile or an attached role:
# AWS_PROFILE=cost-readonly
